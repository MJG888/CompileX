# CompileX – Environment Variables
# Copy this file to .env and fill in your API keys

# ─── Code Execution (Judge0 CE via RapidAPI) ──────────────────────────────────
# Free API key: https://rapidapi.com/judge0-official/api/judge0-ce
# Without this key, CompileX runs in "Demo Mode" with simulated output
VITE_JUDGE0_API_KEY=your_rapidapi_key_here

# ─── AI Assistant (Google Gemini 1.5 Flash) ───────────────────────────────────
# Free API key: https://aistudio.google.com/app/apikey
# Without this key, AI features use pre-written demo responses
VITE_GEMINI_API_KEY=your_gemini_api_key_here
