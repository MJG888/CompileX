# CompileX – Environment Variables
# Copy this file to .env and fill in your API keys

# ─── Backend Connectivity ─────────────────────────────────────────────────────
# For local dev: http://localhost:5000
# For production: https://your-backend-on-render.com
VITE_BACKEND_URL=http://localhost:5000

# ─── Code Execution (Judge0 CE via RapidAPI) ──────────────────────────────────
# Free API key: https://rapidapi.com/judge0-official/api/judge0-ce
VITE_JUDGE0_API_KEY=your_rapidapi_key_here

# ─── AI Assistant (Groq or Gemini) ───────────────────────────────────────────
# Groq (Free/Fast): https://console.groq.com/
VITE_GROQ_API_KEY=your_groq_key_here
# Gemini: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here
